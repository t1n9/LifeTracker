# LifeTracker Backend Configuration Example
# Copy this file to .env and update with your actual values

# ======================================
# Database Configuration
# ======================================
DATABASE_URL="postgresql://lifetracker:password@localhost:5432/lifetracker"

# ======================================
# Application Configuration
# ======================================
NODE_ENV="development"
PORT=3002

# ======================================
# JWT Authentication
# ======================================
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# ======================================
# CORS Configuration
# ======================================
CORS_ORIGIN="http://localhost:3000"

# ======================================
# Security Configuration
# ======================================
BCRYPT_ROUNDS=12

# ======================================
# Email Service Configuration
# ======================================
# Supported providers: qq, gmail, 163
EMAIL_PROVIDER="qq"
EMAIL_USER="your-email@qq.com"
EMAIL_PASSWORD="your-app-specific-password"

# QQ Email: Get app password from Settings > Account > SMTP
# Gmail: Get app-specific password from Google Account settings
# 163 Email: Get auth password from Settings > POP3/SMTP/IMAP

# ======================================
# AI/LLM API Configuration
# ======================================
# DeepSeek V4 (recommended): https://api.deepseek.com/v1/chat/completions
# Models: deepseek-v4-pro (complex reasoning), deepseek-v4-flash (fast/cost-effective)
AI_API_URL="https://api.deepseek.com/v1/chat/completions"
AI_API_KEY="your-deepseek-api-key"
AI_MODEL="deepseek-v4-flash"
AI_TIMEOUT=60000

# ======================================
# File Upload Configuration
# ======================================
MAX_FILE_SIZE=5242880  # 5MB
UPLOAD_DEST="./uploads"

# ======================================
# Rate Limiting
# ======================================
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# ======================================
# Backup Configuration (Optional)
# ======================================
BACKUP_ENABLED=true
BACKUP_INTERVAL="0 2 * * *"  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30

# ======================================
# Redis Configuration (Optional)
# ======================================
# REDIS_URL="redis://localhost:6379"

# ======================================
# Error Tracking (Optional)
# ======================================
# SENTRY_DSN=""
