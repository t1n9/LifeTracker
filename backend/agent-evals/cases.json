    "confirmMode": true,
    "expectedTools": ["create_tasks"],
    "expectedConfirmationCount": 1,
    "mustContain": ["流式测试A", "流式测试B"],
    "mustNotContain": ["任务ID undefined"]
  },
  {
    "name": "完成已有任务使用任务名展示",
    "input": "完成测试任务A",
    "confirmMode": true,
    "taskSeed": ["测试任务A"],
    "expectedTools": ["complete_task"],
    "expectedConfirmationCount": 1,
    "mustContain": ["测试任务A"],
    "mustNotContain": ["任务ID undefined", "undefined"]
  },
  {
    "name": "创建任务并完成应合并为链式操作",
    "input": "创建任务：提交周报，并标记完成",
    "confirmMode": true,
    "expectedTools": ["create_and_complete_task"],
    "expectedConfirmationCount": 1,
    "mustContain": ["提交周报"],
    "mustNotContain": ["任务ID undefined"]
  },
  {
    "name": "创建任务后开启番茄",
