[
  {
    "name": "创建单个任务",
    "input": "创建一个任务：整理 Agent 架构文档",
    "confirmMode": true,
    "expectedTools": ["create_task"],
    "expectedConfirmationCount": 1,
    "mustContain": ["整理 Agent 架构文档"],
    "mustNotContain": ["任务ID undefined"]
  },
  {
    "name": "批量创建任务不重复拆卡",
